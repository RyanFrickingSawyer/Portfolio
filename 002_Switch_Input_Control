#include "driver/gpio.h"

#define SWITCH_PIN 18
#define LED_PIN 19


void app_main(void)
{

    // Configure switch pin as input
    gpio_set_direction(SWITCH_PIN, GPIO_MODE_INPUT);

    // Configure LED pin as output
    gpio_set_direction(LED_PIN, GPIO_MODE_OUTPUT);


    while (1)
    {

        // Read switch state
        int switchState = gpio_get_level(SWITCH_PIN);


        // Write switch state to LED
        gpio_set_level(LED_PIN, switchState);

    }

}
